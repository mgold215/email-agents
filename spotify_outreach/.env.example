# ============================================================
# moodmixformat Spotify Outreach Agent — Environment Variables
# ============================================================
# Copy this file to .env and fill in your real values.
# NEVER commit your .env file to Git — it's already in .gitignore.

# ------------------------------------------------------------
# 1. Claude API Key
#    Get yours at: https://console.anthropic.com/
# ------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ------------------------------------------------------------
# 2. Spotify API Credentials
#    Create a free app at: https://developer.spotify.com/dashboard
#    Set the Redirect URI to http://localhost (required but not used here)
# ------------------------------------------------------------
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# ------------------------------------------------------------
# 3. Gmail Sending Credentials
#    - SENDER_EMAIL: your Gmail address (e.g. yourname@gmail.com)
#    - SENDER_APP_PASSWORD: an App Password, NOT your regular Gmail password
#
#    How to create a Gmail App Password:
#      1. Go to myaccount.google.com
#      2. Security → 2-Step Verification (must be enabled)
#      3. Security → App passwords
#      4. Select "Mail" + "Other (Custom name)" → type "Outreach Agent"
#      5. Copy the 16-character password below
# ------------------------------------------------------------
SENDER_EMAIL=yourname@gmail.com
SENDER_APP_PASSWORD=xxxx xxxx xxxx xxxx
SENDER_NAME=moodmixformat

# ------------------------------------------------------------
# 4. Live Mode Switch
#    IMPORTANT: Leave this as "false" until you've tested everything.
#    Set to "true" ONLY when you are ready to send real emails.
#    In dry-run mode, emails are printed to console but NOT sent.
# ------------------------------------------------------------
OUTREACH_LIVE_MODE=false

# ------------------------------------------------------------
# 5. Rate Limiting
#    How many seconds to wait between each email send.
#    30 seconds is a safe default. Don't go below 10.
# ------------------------------------------------------------
EMAIL_RATE_LIMIT_SECONDS=30
